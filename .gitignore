# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

## .gitignore for CODESFORESP32 (root projects folder)
# Цель: отслеживать только исходники (.c, .h), CMakeLists.txt и idf_component.yml

# ==============================================================================
# Общие правила для всех подпроектов ESP-IDF
# ==============================================================================

# Игнорировать папки сборки
# cmake-build-debug/ - часто генерируется CLion/VS Code CMake Tools
# build/ - стандартная папка сборки ESP-IDF
**/build/
**/cmake-build-debug/

# Игнорировать файлы конфигурации SDK
**/sdkconfig
**/sdkconfig.old

# Игнорировать файлы, специфичные для процесса прошивки/сборки ESP-IDF
**/flasher_args.json
**/flash_project_args
**/bootloader/          # Вся папка загрузчика
**/partitions/           # Вся папка с файлами разделов (если они генерируются)
**/esptool_py/          # Инструменты esptool (генерируются)
**/serial_wrapper/       # Обертка для серийного порта

# ==============================================================================
# Артефакты компилятора и линкера (обычно находятся внутри build/, но могут быть и вне)
# ==============================================================================

# Объектные файлы
**/*.o
**/*.obj
**/*.d     # Файлы зависимостей компилятора

# Исполняемые файлы и образы прошивки
**/*.elf
**/*.bin   # Конечный образ прошивки для ESP32
**/*.hex
**/*.out   # Общий исполняемый файл

# Файлы библиотек
**/*.a     # Статические библиотеки
**/*.lib
**/*.so    # Динамические библиотеки
**/*.dll   # DLL (если вдруг собирается что-то под Windows)
**/*.lo

# Файлы линкера и отладки
**/*.map   # Карта памяти
**/*.su    # Summary of structure usage (информация об использовании стека)
**/*.pdb   # Отладочные символы Windows
**/*.dSYM/ # Отладочные символы macOS (папка)

# Предкомпилированные заголовки
**/*.gch
**/*.pch

# ==============================================================================
# Файлы, специфичные для IDE (VS Code) и среды разработки
# ==============================================================================

# Игнорировать папку .vscode/ и её содержимое в корне (CODESFORESP32/.vscode/)
# Это для настроек рабочей области VS Code, а не для проектов.
.vscode/

# Игнорировать папки .vscode/ и их содержимое внутри КАЖДОГО подпроекта (например, ClockProjectV3/.vscode/)
# Если вы хотите игнорировать только некоторые файлы внутри .vscode/,
# раскомментируйте следующие строки и закомментируйте/удалите строку выше.
# **/.vscode/c_cpp_properties.json
# **/.vscode/settings.json
# **/.vscode/tasks.json
# **/.vscode/*.log

# IDE .idea/ - для CLion или других JetBrains IDE
**/.idea/

# Python virtual environment (если вы используете venv внутри проектов)
**/venv/

# Файлы конфигурации инструментов (например, PlatformIO, если вы его используете)
# **/.pio/
# **/platformio.ini

# ==============================================================================
# Временные файлы и файлы ОС
# ==============================================================================
**/*.log    # Все файлы логов на любом уровне
*.log      # Логи прямо в корневой папке
*.tmp      # Временные файлы
*~         # Резервные копии файлов (например, от Vim)
.DS_Store  # macOS specific
Thumbs.db  # Windows specific